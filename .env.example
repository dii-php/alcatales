# Cloudinary Configuration
REACT_APP_CLOUDINARY_CLOUD_NAME=your_cloud_name
REACT_APP_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Admin Credentials (change these!)
REACT_APP_ADMIN_USERNAME=aldi
REACT_APP_ADMIN_PASSWORD=admin123

# Firebase Configuration (for persistent data storage)
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id

# YouTube Data API v3 (for song search in Love Letter)
REACT_APP_YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Resend (email notifications) ──────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# ── Firebase Admin (for serverless functions) ─────────────
# Get from Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Internal notify key (random string, you choose) ────────
# Must match in both REACT_APP_ (frontend) and without prefix (serverless)
REACT_APP_INTERNAL_NOTIFY_KEY=random_secret_string_here
INTERNAL_NOTIFY_KEY=random_secret_string_here
